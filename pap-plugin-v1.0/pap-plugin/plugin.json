{
  "name": "pap",
  "displayName": "Personal Automation Platform",
  "version": "1.0.0",
  "description": "An always-on AI agent system that automates tasks while you sleep. Built on Cowork with a Discord-first interface, second brain, and self-improvement system.",
  "author": {
    "name": "PAP Project",
    "url": "https://pap-ai.github.io/pap"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pap-ai/pap"
  },
  "license": "MIT",
  "homepage": "https://pap-ai.github.io/pap",

  "skills": [
    "skills/lean-startup.md",
    "skills/curiosity-interviewer.md",
    "skills/capability-audit.md",
    "skills/agent-directory.md",
    "skills/output-validator.md",
    "skills/credential-vault-guide.md",
    "skills/sms-2fa.md",
    "skills/bml-memory-checkpoint.md",
    "skills/ui-designer.md",
    "skills/humanizer.md"
  ],

  "agents": [
    "agents/dispatcher.md",
    "agents/help.md",
    "agents/curiosity.md",
    "agents/scaffolder.md",
    "agents/executor.md",
    "agents/validator.md",
    "agents/security.md",
    "agents/steward.md",
    "agents/cost-monitor.md",
    "agents/performance-monitor.md",
    "agents/connector.md",
    "agents/synthesizer.md"
  ],

  "commands": [
    "commands/new-workspace.md",
    "commands/capture.md",
    "commands/status.md",
    "commands/pause.md",
    "commands/resume.md"
  ],

  "onboarding": {
    "skill": "onboarding/onboarding-skill.md",
    "autoFireOnInstall": true
  },

  "templates": [
    "templates/workspace-claude-md.md",
    "templates/spec-md.md",
    "templates/tasks-md.md",
    "templates/decisions-md.md",
    "templates/pinned-card.md"
  ],

  "discord": {
    "required": true,
    "setupMethod": "bot_token",
    "setupDuringOnboarding": true,
    "note": "PAP requires Discord. Setup is guided during onboarding."
  },

  "connectors": {
    "required": [],
    "optional": [
      "google-drive",
      "google-calendar",
      "gmail",
      "onedrive",
      "outlook-calendar",
      "outlook-email",
      "1password",
      "bitwarden",
      "slack",
      "notion"
    ]
  },

  "permissions": {
    "fileSystem": {
      "read": ["~/.claude/", "~/pap-workspace/"],
      "write": ["~/.claude/", "~/pap-workspace/"]
    },
    "computerUse": {
      "required": false,
      "requestDuringOnboarding": true
    },
    "claudeInChrome": {
      "required": false,
      "requestDuringOnboarding": true
    },
    "network": {
      "outbound": ["api.anthropic.com", "discord.com", "github.com"]
    }
  },

  "updatePolicy": {
    "minor": "auto",
    "major": "askUser",
    "rollbackOnValidationFailure": true
  },

  "minimumClaudeDesktopVersion": "1.0.0",
  "supportedPlatforms": ["macOS", "Windows"]
}
